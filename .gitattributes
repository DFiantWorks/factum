# Normalise text files; keep shell scripts LF so they run under Git Bash on
# Windows (CRLF would break `bash` and the Mill bootstrap), and keep .bat CRLF.
* text=auto

mill           text eol=lf
*.sh           text eol=lf
*.scala        text eol=lf
*.mill         text eol=lf
*.yml          text eol=lf
*.bat          text eol=crlf
